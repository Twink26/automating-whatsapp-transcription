# OpenAI (for Whisper transcription)
OPENAI_API_KEY=sk-xxxxxxxx

# Anthropic (for speaker classification, summarization, action items)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./service-account.json
GOOGLE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: comma-separated list of group JIDs to listen to.
# Leave empty to listen to ALL groups the linked WhatsApp account is part of.
# Format example: 1203630xxxxxx@g.us,1203630yyyyy@g.us
ALLOWED_GROUP_JIDS=
